# ============ LLM Providers ============

# --- 火山方舟 Ark - doubao-seed-evolving (planner) ---
# https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Model endpoint id or model name; can be the inference endpoint id starting with "ep-"
DOUBAO_MODEL=doubao-seed-evolving

# --- DeepSeek (synthesizer) ---
# https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============ Web search ============
TAVILY_API_KEY=your_tavily_api_key_here

# ============ Runtime ============
FA_DATA_DIR=./data
FA_OUTPUT_DIR=./outputs
FA_DB_PATH=./data/finance_agent.db
FA_CACHE_DIR=./data/cache
FA_LOG_LEVEL=INFO
